---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTopics = await getCollection('topics');
// Sort by order, then alphabetically
allTopics.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Topics - Cloud Docs">
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-zinc-50 mb-4">Topics</h1>
    <p class="text-lg text-zinc-600 dark:text-zinc-400">In-depth guides and best practices.</p>
  </div>

  <div class="space-y-4">
    {allTopics.map((topic) => (
      <a href={`/topics/${topic.slug}`} class="block group">
        <div class="bg-white dark:bg-zinc-900 rounded-xl border border-zinc-200 dark:border-zinc-800 p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md hover:border-primary-500/30 dark:hover:border-primary-500/30 flex justify-between items-center">
          <div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-1">
              {topic.data.title}
            </h2>
            {topic.data.description && (
              <p class="text-zinc-600 dark:text-zinc-400 text-sm">
                {topic.data.description}
              </p>
            )}
          </div>
          <svg class="w-5 h-5 text-zinc-400 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>